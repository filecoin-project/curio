DOCKER_USER=curio
LOTUS_IMAGE=${DOCKER_USER}/lotus-dev:dev
LOTUS_MINER_IMAGE=${DOCKER_USER}/lotus-miner-dev:dev
CURIO_IMAGE=${DOCKER_USER}/curio-dev:dev
CONTRACTS_BOOTSTRAP_IMAGE=${DOCKER_USER}/contracts-bootstrap-dev:dev
PIECE_SERVER_IMAGE=${DOCKER_USER}/piece-server-dev:dev
INDEXER_IMAGE=${DOCKER_USER}/indexer-dev:dev
FIL_PROOFS_PARAMETER_CACHE=${HOME}/.cache/filecoin-proof-parameters

FILECOIN_SERVICES_REPO=https://github.com/FilOzone/filecoin-services.git
FILECOIN_SERVICES_REF=v1.1.0
MULTICALL3_REPO=https://github.com/mds1/multicall3.git
MULTICALL3_REF=b667d67ecfa5361a81e8f110234ce242613b0012
CONTRACT_SOURCE_MODE=local
FILECOIN_SERVICES_LOCAL_DIR=./local-src/filecoin-services
MULTICALL3_LOCAL_DIR=./local-src/multicall3

CONTRACT_SERVICE_NAME=curio-devnet
CONTRACT_SERVICE_DESCRIPTION=Curio devnet warm storage service
CONTRACT_DEPLOYER_PASSWORD=devnet
DEPLOYER_FUND_AMOUNT_FIL=5000
FORCE_REDEPLOY=false
