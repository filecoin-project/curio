// Jacobian G1 add (short Weierstrass a=0): `POINT_add` + `POINT_double` from `ec-gpu-gen/src/cl/ec.cl`.
// SSBO `d[108]`: out (0..35) = a+b; in a (36..71), in b (72..107). Montgomery `Fp` limbs (@@FP_T@@).

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) buffer Data {
    uint d[108];
} buf;

void fp_load_j(uint base, out @@FP_T@@ x) {
    for (uint i = 0u; i < 12u; i++) {
        x.val[i] = buf.d[base + i];
    }
}

void fp_store_j(uint base, @@FP_T@@ x) {
    for (uint i = 0u; i < 12u; i++) {
        buf.d[base + i] = x.val[i];
    }
}

void jac_double(inout @@FP_T@@ ix, inout @@FP_T@@ iy, inout @@FP_T@@ iz) {
    if (fp_is_zero(iz)) {
        return;
    }
    @@FP_T@@ A = fp_mul_mont_cios(ix, ix);
    @@FP_T@@ B = fp_mul_mont_cios(iy, iy);
    @@FP_T@@ C = fp_mul_mont_cios(B, B);
    @@FP_T@@ d = fp_add_mod(ix, B);
    d = fp_mul_mont_cios(d, d);
    d = fp_sub_mod(fp_sub_mod(d, A), C);
    d = fp_dbl(d);
    @@FP_T@@ e = fp_add_mod(fp_dbl(A), A);
    @@FP_T@@ f = fp_mul_mont_cios(e, e);
    iz = fp_mul_mont_cios(iy, iz);
    iz = fp_dbl(iz);
    ix = fp_sub_mod(fp_sub_mod(f, d), d);
    C = fp_dbl(C);
    C = fp_dbl(C);
    C = fp_dbl(C);
    iy = fp_sub_mod(fp_mul_mont_cios(fp_sub_mod(d, ix), e), C);
}

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }
    @@FP_T@@ ax;
    @@FP_T@@ ay;
    @@FP_T@@ az;
    @@FP_T@@ bx;
    @@FP_T@@ by;
    @@FP_T@@ bz;
    fp_load_j(36u, ax);
    fp_load_j(48u, ay);
    fp_load_j(60u, az);
    fp_load_j(72u, bx);
    fp_load_j(84u, by);
    fp_load_j(96u, bz);

    if (fp_is_zero(az)) {
        fp_store_j(0u, bx);
        fp_store_j(12u, by);
        fp_store_j(24u, bz);
        return;
    }
    if (fp_is_zero(bz)) {
        fp_store_j(0u, ax);
        fp_store_j(12u, ay);
        fp_store_j(24u, az);
        return;
    }

    @@FP_T@@ z1z1 = fp_mul_mont_cios(az, az);
    @@FP_T@@ z2z2 = fp_mul_mont_cios(bz, bz);
    @@FP_T@@ u1 = fp_mul_mont_cios(ax, z2z2);
    @@FP_T@@ u2 = fp_mul_mont_cios(bx, z1z1);
    @@FP_T@@ s1 = fp_mul_mont_cios(fp_mul_mont_cios(ay, bz), z2z2);
    @@FP_T@@ s2 = fp_mul_mont_cios(fp_mul_mont_cios(by, az), z1z1);

    if (fp_eq(u1, u2) && fp_eq(s1, s2)) {
        jac_double(ax, ay, az);
        fp_store_j(0u, ax);
        fp_store_j(12u, ay);
        fp_store_j(24u, az);
        return;
    }

    @@FP_T@@ h = fp_sub_mod(u2, u1);
    @@FP_T@@ i = fp_dbl(h);
    i = fp_mul_mont_cios(i, i);
    @@FP_T@@ j = fp_mul_mont_cios(h, i);
    @@FP_T@@ r = fp_dbl(fp_sub_mod(s2, s1));
    @@FP_T@@ v = fp_mul_mont_cios(u1, i);
    @@FP_T@@ rx = fp_sub_mod(fp_sub_mod(fp_sub_mod(fp_mul_mont_cios(r, r), j), v), v);
    @@FP_T@@ ry = fp_mul_mont_cios(fp_sub_mod(v, rx), r);
    s1 = fp_dbl(fp_mul_mont_cios(s1, j));
    ry = fp_sub_mod(ry, s1);
    @@FP_T@@ rz = fp_add_mod(az, bz);
    rz = fp_mul_mont_cios(rz, rz);
    rz = fp_sub_mod(fp_sub_mod(rz, z1z1), z2z2);
    rz = fp_mul_mont_cios(rz, h);

    fp_store_j(0u, rx);
    fp_store_j(12u, ry);
    fp_store_j(24u, rz);
}
