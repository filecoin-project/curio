# Skiff image tag (used by `docker compose build` / `up`).
SKIFF_IMAGE=curio/skiff:dev

# Network build target for the skiff binary.
#   skiff (mainnet, default) | calibnet-skiff | 2k-skiff
SKIFF_MAKE_TARGET=skiff

# Yugabyte image.
YUGABYTE_IMAGE=yugabytedb/yugabyte:2024.1.0.0-b129

# Host paths for persistent storage.
YUGABYTE_DATA=./data/yugabyte
SKIFF_REPO_DATA=./data/skiff
SKIFF_STORAGE=./data

# Public PDP API hostname seeded into the base config layer on first start.
SKIFF_HTTP_DOMAIN=localhost

# Required: Lotus-compatible chain node RPC (must match skiff build network).
# Skiff does not embed a chain node — see documentation/en/curio-pdp.md § "Configure .env".
# If Lotus runs on the Docker host, use host.docker.internal (not 127.0.0.1):
# FULLNODE_API_INFO=/ip4/host.docker.internal/tcp/1234/http
FULLNODE_API_INFO=
