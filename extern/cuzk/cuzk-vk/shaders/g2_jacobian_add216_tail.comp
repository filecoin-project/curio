// G2 Jacobian add (Fp2 Montgomery limbs): same distinct-point / double split as `g1_jacobian_add108_tail.comp`.
// SSBO `d[216]`: out (0..71), a (72..143), b (144..215). Each coordinate is 24 × `u32` (`c0||c1`).

layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) buffer Data {
    uint d[216];
} buf;

void load_fp2(uint w, out @@FP_T@@ c0, out @@FP_T@@ c1) {
    for (uint i = 0u; i < 12u; i++) {
        c0.val[i] = buf.d[w + i];
        c1.val[i] = buf.d[w + 12u + i];
    }
}

void store_fp2(uint w, @@FP_T@@ c0, @@FP_T@@ c1) {
    for (uint i = 0u; i < 12u; i++) {
        buf.d[w + i] = c0.val[i];
        buf.d[w + 12u + i] = c1.val[i];
    }
}

void jac_double_g2(inout @@FP_T@@ ix0, inout @@FP_T@@ ix1, inout @@FP_T@@ iy0, inout @@FP_T@@ iy1, inout @@FP_T@@ iz0, inout @@FP_T@@ iz1) {
    if (fp2_is_zero(iz0, iz1)) {
        return;
    }
    @@FP_T@@ A0;
    @@FP_T@@ A1;
    fp2_sqr_m(ix0, ix1, A0, A1);
    @@FP_T@@ B0;
    @@FP_T@@ B1;
    fp2_sqr_m(iy0, iy1, B0, B1);
    @@FP_T@@ C0;
    @@FP_T@@ C1;
    fp2_sqr_m(B0, B1, C0, C1);
    @@FP_T@@ d0;
    @@FP_T@@ d1;
    fp2_add_c(ix0, ix1, B0, B1, d0, d1);
    fp2_sqr_m(d0, d1, d0, d1);
    @@FP_T@@ t0;
    @@FP_T@@ t1;
    fp2_sub_c(d0, d1, A0, A1, t0, t1);
    fp2_sub_c(t0, t1, C0, C1, d0, d1);
    fp2_dbl_c(d0, d1, d0, d1);
    @@FP_T@@ e0;
    @@FP_T@@ e1;
    fp2_dbl_c(A0, A1, e0, e1);
    fp2_add_c(e0, e1, A0, A1, e0, e1);
    @@FP_T@@ f0;
    @@FP_T@@ f1;
    fp2_sqr_m(e0, e1, f0, f1);
    fp2_mul_m(iy0, iy1, iz0, iz1, iz0, iz1);
    fp2_dbl_c(iz0, iz1, iz0, iz1);
    fp2_sub_c(f0, f1, d0, d1, ix0, ix1);
    fp2_sub_c(ix0, ix1, d0, d1, ix0, ix1);
    fp2_dbl_c(C0, C1, C0, C1);
    fp2_dbl_c(C0, C1, C0, C1);
    fp2_dbl_c(C0, C1, C0, C1);
    @@FP_T@@ u0;
    @@FP_T@@ u1;
    fp2_sub_c(d0, d1, ix0, ix1, u0, u1);
    fp2_mul_m(u0, u1, e0, e1, iy0, iy1);
    fp2_sub_c(iy0, iy1, C0, C1, iy0, iy1);
}

void main() {
    if (gl_GlobalInvocationID.x != 0u) {
        return;
    }
    @@FP_T@@ ax0;
    @@FP_T@@ ax1;
    @@FP_T@@ ay0;
    @@FP_T@@ ay1;
    @@FP_T@@ az0;
    @@FP_T@@ az1;
    @@FP_T@@ bx0;
    @@FP_T@@ bx1;
    @@FP_T@@ by0;
    @@FP_T@@ by1;
    @@FP_T@@ bz0;
    @@FP_T@@ bz1;
    load_fp2(72u, ax0, ax1);
    load_fp2(96u, ay0, ay1);
    load_fp2(120u, az0, az1);
    load_fp2(144u, bx0, bx1);
    load_fp2(168u, by0, by1);
    load_fp2(192u, bz0, bz1);

    if (fp2_is_zero(az0, az1)) {
        store_fp2(0u, bx0, bx1);
        store_fp2(24u, by0, by1);
        store_fp2(48u, bz0, bz1);
        return;
    }
    if (fp2_is_zero(bz0, bz1)) {
        store_fp2(0u, ax0, ax1);
        store_fp2(24u, ay0, ay1);
        store_fp2(48u, az0, az1);
        return;
    }

    @@FP_T@@ z1z10;
    @@FP_T@@ z1z11;
    fp2_sqr_m(az0, az1, z1z10, z1z11);
    @@FP_T@@ z2z20;
    @@FP_T@@ z2z21;
    fp2_sqr_m(bz0, bz1, z2z20, z2z21);
    @@FP_T@@ u10;
    @@FP_T@@ u11;
    fp2_mul_m(ax0, ax1, z2z20, z2z21, u10, u11);
    @@FP_T@@ u20;
    @@FP_T@@ u21;
    fp2_mul_m(bx0, bx1, z1z10, z1z11, u20, u21);
    @@FP_T@@ s10;
    @@FP_T@@ s11;
    fp2_mul_m(ay0, ay1, bz0, bz1, s10, s11);
    fp2_mul_m(s10, s11, z2z20, z2z21, s10, s11);
    @@FP_T@@ s20;
    @@FP_T@@ s21;
    fp2_mul_m(by0, by1, az0, az1, s20, s21);
    fp2_mul_m(s20, s21, z1z10, z1z11, s20, s21);

    if (fp2_eq(u10, u11, u20, u21) && fp2_eq(s10, s11, s20, s21)) {
        jac_double_g2(ax0, ax1, ay0, ay1, az0, az1);
        store_fp2(0u, ax0, ax1);
        store_fp2(24u, ay0, ay1);
        store_fp2(48u, az0, az1);
        return;
    }

    @@FP_T@@ h0;
    @@FP_T@@ h1;
    fp2_sub_c(u20, u21, u10, u11, h0, h1);
    @@FP_T@@ hh0;
    @@FP_T@@ hh1;
    fp2_sqr_m(h0, h1, hh0, hh1);
    @@FP_T@@ hhh0;
    @@FP_T@@ hhh1;
    fp2_mul_m(h0, h1, hh0, hh1, hhh0, hhh1);
    @@FP_T@@ r0;
    @@FP_T@@ r1;
    fp2_sub_c(s20, s21, s10, s11, r0, r1);
    @@FP_T@@ v0;
    @@FP_T@@ v1;
    fp2_mul_m(u10, u11, hh0, hh1, v0, v1);
    @@FP_T@@ i0;
    @@FP_T@@ i1;
    fp2_sqr_m(r0, r1, i0, i1);
    @@FP_T@@ rx0;
    @@FP_T@@ rx1;
    fp2_sub_c(i0, i1, hhh0, hhh1, rx0, rx1);
    @@FP_T@@ j0;
    @@FP_T@@ j1;
    fp2_dbl_c(v0, v1, j0, j1);
    fp2_sub_c(rx0, rx1, j0, j1, rx0, rx1);
    @@FP_T@@ ry0;
    @@FP_T@@ ry1;
    fp2_sub_c(v0, v1, rx0, rx1, ry0, ry1);
    fp2_mul_m(ry0, ry1, r0, r1, ry0, ry1);
    fp2_mul_m(s10, s11, hhh0, hhh1, i0, i1);
    fp2_sub_c(ry0, ry1, i0, i1, ry0, ry1);
    @@FP_T@@ rz0;
    @@FP_T@@ rz1;
    fp2_mul_m(az0, az1, bz0, bz1, rz0, rz1);
    fp2_mul_m(rz0, rz1, h0, h1, rz0, rz1);

    store_fp2(0u, rx0, rx1);
    store_fp2(24u, ry0, ry1);
    store_fp2(48u, rz0, rz1);
}
