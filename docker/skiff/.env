# MaxBoom image tag (used by `docker compose build` / `up`).
MAXBOOM_IMAGE=curio/maxboom:dev

# Network build target for the maxboom binary.
#   maxboom (mainnet, default) | calibnet-maxboom | 2k-maxboom
MAXBOOM_MAKE_TARGET=maxboom

# Yugabyte image.
YUGABYTE_IMAGE=yugabytedb/yugabyte:2024.1.0.0-b129

# Host paths for persistent storage.
YUGABYTE_DATA=./data/yugabyte
MAXBOOM_REPO_DATA=./data/maxboom
MAXBOOM_STORAGE=./data

# Public PDP API hostname seeded into the base config layer on first start.
MAXBOOM_HTTP_DOMAIN=localhost
