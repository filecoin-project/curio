// Pippenger bucket accumulate — one thread per **(circuit, bucket)** pair (unsigned digit buckets).
//
// SSBO layout (u32 words):
//   d[0]               = reserved (0)
//   d[1]               = bucket_count (= 1 << window_bits)
//   d[2]               = batch_circuits (circuits in this dispatch; ≥ 1, ≤ G1_PIPP_MAX_BATCH)
//   d[3]               = N_tot packed affine+digit slots (= circuit_start[batch])
//   d[4]               = affine_layout (0=dense row pi; 1=indexed via base_idx[pi] into pool)
//   d[5]               = unique_affine_rows (pool rows used; = N_tot dense, = |pool| indexed)
//   d[6..64)           = reserved / zero
//   d[64 .. 64+129)    = circuit_start[c] for c = 0..batch and padded; start[0]=0, start[batch]=N_tot
//   d[OFF_DIG .. OFF_DIG+N_tot)           = digits (global index same as affine packing order)
//   d[OFF_BASE_IDX .. OFF_BASE_IDX+N_tot) = base_idx[pi] when affine_layout==1; zero in dense mode
//   d[OFF_AFF_POOL .. OFF_AFF_POOL+24*G1_PIPP_MAX_N) = Montgomery x||y pool (24 u32 / row)
//   d[OFF_BUCKET_JAC + (c*bucket_count+b)*36 ..+36) = Jacobian bucket b for local circuit index c
//
// Variable **per-circuit** lengths: circuit **c** uses global digit indices **[start[c], start[c+1])**.
//
// Uses the same straight-line EFD accumulation pattern as `g1_batch_accum_bitmap1636_tail.comp`.
//
// **§8.3 C.3:** For `layout(local_size_x_id = 0)` + host specialization, keep logic aligned with
// `g1_pippenger_bucket_acc_spec_tail.comp` (glslang path in `build.rs`).

#define G1_PIPP_LOCAL_X     256u
#define G1_PIPP_MAX_N       16384u
#define G1_PIPP_MAX_BUCKET  65536u
#define G1_PIPP_MAX_BATCH   128u

#define OFF_RESERVED        0u
#define OFF_BUCKET_COUNT    1u
#define OFF_BATCH           2u
#define OFF_POINT_TOTAL     3u
#define OFF_AFFINE_MODE     4u
#define OFF_UNIQUE_AFF      5u
#define OFF_CIRCUIT_START   64u
#define OFF_DIG             (OFF_CIRCUIT_START + G1_PIPP_MAX_BATCH + 1u)
#define OFF_BASE_IDX        (OFF_DIG + G1_PIPP_MAX_N)
#define OFF_AFF_POOL        (OFF_BASE_IDX + G1_PIPP_MAX_N)
#define OFF_BUCKET_JAC      (OFF_AFF_POOL + G1_PIPP_MAX_N * 24u)

#define SSBO_WORDS          (OFF_BUCKET_JAC + G1_PIPP_MAX_BUCKET * 36u)

layout(local_size_x = G1_PIPP_LOCAL_X, local_size_y = 1, local_size_z = 1) in;

layout(set = 0, binding = 0) buffer Data {
    uint d[SSBO_WORDS];
} buf;

void main() {
    uint bucket_count = buf.d[OFF_BUCKET_COUNT];
    uint batch = buf.d[OFF_BATCH];
    if (batch < 1u) {
        batch = 1u;
    }
    if (batch > G1_PIPP_MAX_BATCH) {
        batch = G1_PIPP_MAX_BATCH;
    }

    uint total_jobs = batch * bucket_count;
    uint tid = gl_GlobalInvocationID.x;
    if (tid >= total_jobs) {
        return;
    }
    uint c = tid / bucket_count;
    uint b = tid - c * bucket_count;

    uint start_c = buf.d[OFF_CIRCUIT_START + c];
    uint end_c = buf.d[OFF_CIRCUIT_START + c + 1u];

    uint aff_layout = buf.d[OFF_AFFINE_MODE];
    uint uniq_aff = buf.d[OFF_UNIQUE_AFF];

    // Running Jacobian accumulator for this bucket — Z=0 encodes the identity.
    @@FP_T@@ ax;
    @@FP_T@@ ay;
    @@FP_T@@ az;
    for (uint i = 0u; i < 12u; i++) {
        ax.val[i] = 0u;
        ay.val[i] = 0u;
        az.val[i] = 0u;
    }
    @@FP_T@@ bz_one = fp_one();

    for (uint pi = start_c; pi < end_c && pi < G1_PIPP_MAX_N; pi += 1u) {
        if (buf.d[OFF_DIG + pi] != b) {
            continue;
        }

        uint bi = (aff_layout == 0u) ? pi : buf.d[OFF_BASE_IDX + pi];
        if (aff_layout == 1u && bi >= uniq_aff) {
            continue;
        }

        uint ab = OFF_AFF_POOL + bi * 24u;
        @@FP_T@@ bx;
        @@FP_T@@ by;
        for (uint i = 0u; i < 12u; i++) {
            bx.val[i] = buf.d[ab + i];
            by.val[i] = buf.d[ab + 12u + i];
        }
        @@FP_T@@ bz = bz_one;

        @@FP_T@@ ax0;
        @@FP_T@@ ay0;
        @@FP_T@@ az0;
        uint az_nz = 0u;
        for (uint i = 0u; i < 12u; i++) {
            ax0.val[i] = ax.val[i];
            ay0.val[i] = ay.val[i];
            az0.val[i] = az.val[i];
            if (az.val[i] != 0u) { az_nz = az_nz + 1u; }
        }

        @@FP_T@@ z1z1  = fp_mul_mont_cios(az0, az0);
        @@FP_T@@ z2z2  = fp_mul_mont_cios(bz,  bz);
        @@FP_T@@ u1    = fp_mul_mont_cios(ax0, z2z2);
        @@FP_T@@ u2    = fp_mul_mont_cios(bx,  z1z1);
        @@FP_T@@ ay_bz = fp_mul_mont_cios(ay0, bz);
        @@FP_T@@ s1    = fp_mul_mont_cios(ay_bz, z2z2);
        @@FP_T@@ by_az = fp_mul_mont_cios(by,  az0);
        @@FP_T@@ s2    = fp_mul_mont_cios(by_az, z1z1);
        @@FP_T@@ h     = fp_sub_mod(u2, u1);
        @@FP_T@@ hh    = fp_mul_mont_cios(h,  h);
        @@FP_T@@ hhh   = fp_mul_mont_cios(h,  hh);
        @@FP_T@@ r     = fp_sub_mod(s2, s1);
        @@FP_T@@ v     = fp_mul_mont_cios(u1, hh);
        @@FP_T@@ r2    = fp_mul_mont_cios(r,  r);
        @@FP_T@@ twov  = fp_dbl(v);
        @@FP_T@@ r2mhhh = fp_sub_mod(r2,   hhh);
        @@FP_T@@ rx    = fp_sub_mod(r2mhhh, twov);
        @@FP_T@@ vmrx  = fp_sub_mod(v,  rx);
        @@FP_T@@ ry_a  = fp_mul_mont_cios(vmrx, r);
        @@FP_T@@ s1hhh = fp_mul_mont_cios(s1,  hhh);
        @@FP_T@@ ry    = fp_sub_mod(ry_a, s1hhh);
        @@FP_T@@ az_bz = fp_mul_mont_cios(az0, bz);
        @@FP_T@@ rz    = fp_mul_mont_cios(az_bz, h);

        uint acc_first = (az_nz == 0u) ? 1u : 0u;
        if (acc_first == 1u) {
            for (uint i = 0u; i < 12u; i++) {
                ax.val[i] = bx.val[i];
                ay.val[i] = by.val[i];
                az.val[i] = bz.val[i];
            }
        } else {
            for (uint i = 0u; i < 12u; i++) {
                ax.val[i] = rx.val[i];
                ay.val[i] = ry.val[i];
                az.val[i] = rz.val[i];
            }
        }
    }

    uint ob = OFF_BUCKET_JAC + (c * bucket_count + b) * 36u;
    for (uint i = 0u; i < 12u; i++) {
        buf.d[ob + i]       = ax.val[i];
        buf.d[ob + 12u + i] = ay.val[i];
        buf.d[ob + 24u + i] = az.val[i];
    }
}
